{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2022"],
    "paths": {
      "@shared/*": ["../../src/shared/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../../src/shared/rule-pack.ts",
    "../../src/shared/types.ts",
    "../../src/shared/ai.ts"
  ]
}
